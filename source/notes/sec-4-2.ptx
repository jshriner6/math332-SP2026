      <exercise workspace="8in">
            <title>Example 1: Verifying Properties</title>
            <statement>
                <p>
                    Consider
                    <md>
                        \varphi'' = -\lambda \varphi, \varphi(0)= \varphi(\pi) =0 
                    </md>.
                    
                </p>
            </statement>
            
        
      </exercise>

	  <exercise workspace="8in">
            <title>Example 2: Verifying Properties</title>
            <statement>
                <p>
                    Consider
                    <md>
                        (x \varphi')' + \frac{2}{x}\varphi = -\frac{\lambda}{x} \varphi, \varphi'(1)= \varphi'(2) =0 
                    </md>.
                    
                </p>
            </statement>
            
        
      </exercise>

