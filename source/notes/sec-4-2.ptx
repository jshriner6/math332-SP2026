	  <exercise workspace="8in">
            <title>Example 1: Using the Rayleigh Quotient</title>
            <statement>
                <p>
                  Consider
                  <md>
                    \varphi'' + \lambda \varphi = 0, \varphi(0)=\varphi(\pi)=0
